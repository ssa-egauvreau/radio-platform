{
  "name": "security-radio-desktop-console",
  "version": "0.1.0",
  "private": true,
  "description": "Native desktop shell for the Security Radio dispatch console.",
  "author": "Security Radio",
  "license": "UNLICENSED",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.securityradio.dispatchconsole",
    "productName": "Security Radio Dispatch Console",
    "files": ["electron/**/*"],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Dispatch voice transmit uses the microphone."
      }
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    }
  }
}
